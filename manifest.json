{
  "manifest_version": 3,
  "name": "Verum Signal",
  "version": "1.3",
  "description": "See claim-level reliability scores for any news article. Evidence-based, methodology-driven, no editorial labels.",
  "author": "Verum Signal",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://verumsignal.com/*",
    "https://www.verumsignal.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Verum Signal",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
